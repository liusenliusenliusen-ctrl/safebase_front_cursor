# 本地：supabase start 后执行 supabase status 查看 API URL 与 anon key
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your_anon_key_from_supabase_status

# 生产构建：改为服务器上 Supabase API 的公网地址（见 docs/DEPLOYMENT.md）
# VITE_SUPABASE_URL=https://api.yourdomain.com
# VITE_SUPABASE_ANON_KEY=...

# OPENROUTER_API_KEY 写在 supabase/functions/.env（本地）或 supabase secrets set（生产）
# 勿写进本文件（会打进前端 bundle，且 Edge 读不到）
