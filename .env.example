# 本地 Supabase（默认 https://supabase.com/docs/guides/cli/local-development）
VITE_SUPABASE_URL=http://127.0.0.1:54321
# Dashboard → Project Settings → API → anon public key（勿将 service_role 写入前端）
VITE_SUPABASE_ANON_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# 可选：若 Edge Function 不在默认 URL 下再覆盖
# VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# OPENROUTER_API_KEY：本地写在 supabase/functions/.env；远程用 supabase secrets set
# 勿写进本文件（Vite 会打进前端，且 Edge 读不到）。
