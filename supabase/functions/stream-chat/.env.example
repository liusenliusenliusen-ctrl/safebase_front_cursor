# 本地（supabase start）：在 supabase/functions/.env 写 OPENROUTER_API_KEY（推荐）
# 或复制本文件为同目录 .env，仅在使用 supabase functions serve stream-chat 时生效
# 远程：supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...  或 Dashboard → Edge Functions → Secrets

OPENROUTER_API_KEY=
# 可选（默认与 backend .env.example 一致）
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_CHAT_MODEL=deepseek/deepseek-chat
# DB 为 vector(2048)：用 large（small 最高 1536 维，会报 empty vector / dimensions 错误）
# OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-large
# OPENROUTER_EMBEDDING_DIMENSIONS=2048
# OPENROUTER_HTTP_REFERER=https://your-site.example
# OPENROUTER_APP_TITLE=Safebase
